APP_ADMIN_USER=admin
APP_ADMIN_PASSWORD=change-this-password

# Host port published by docker-compose.
MONGOOSE_HOST_PORT=8000

# The curl-impersonate package used by this image is verified on linux/amd64.
# Leave this as-is on ordinary x86_64 servers. Apple Silicon / ARM hosts need
# Docker's amd64 emulation support.
MONGOOSE_PLATFORM=linux/amd64

# Set to 1 when you intentionally want to reset the stored admin password.
APP_RESET_ADMIN_PASSWORD=0

# Use 1 behind an HTTPS reverse proxy.
APP_COOKIE_SECURE=0

# Use 1 when a trusted reverse proxy should supply X-Forwarded-For.
APP_TRUST_PROXY=0

# Local-only debugging escape hatch. Do not enable on public deployments.
APP_AUTH_DISABLED=0
